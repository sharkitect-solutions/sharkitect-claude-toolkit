[
  {
    "event": "PostToolUse",
    "matcher": "Write|Edit",
    "hooks": [
      {
        "type": "command",
        "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/phase-gate-watch.py\""
      }
    ]
  },
  {
    "event": "Stop",
    "hooks": [
      {
        "type": "command",
        "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/phase-gate-stop.py\""
      }
    ]
  },
  {
    "event": "PreCompact",
    "hooks": [
      {
        "type": "command",
        "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/phase-gate-preserve.py\""
      }
    ]
  }
]